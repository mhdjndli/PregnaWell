# ============================================================
# Required for the /admin panel
# ============================================================

# The single password to log into /admin. Choose anything strong.
ADMIN_PASSWORD=change-me-to-something-strong

# Postgres connection string. On Railway, add a "Postgres" plugin
# and Railway will set this automatically — leave it blank locally
# unless you want admin to work offline.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to "disable" to turn off SSL on local Postgres.
# Defaults to require-SSL in production.
# PGSSLMODE=disable

# ============================================================
# Optional: "Generate with Gemini" cover image button in admin
# ============================================================

# Google AI Studio API key — enables the "Generate with Gemini"
# button in the blog editor's cover image card. Get one at
# https://aistudio.google.com/app/apikey. If unset, the button
# will return a configuration error when clicked.
# GEMINI_API_KEY=
